---
import '../styles/global.css';
const { currentPath = '/' } = Astro.props;
const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/about', label: 'About' },
	{ href: '/cv', label: 'CV' },
	{ href: '/projects', label: 'Projects' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Portfolio of a game developer seeking opportunities in interactive media and game production." />
		<link rel="icon" type="image/svg+xml" href="/favicon.png" />
		<link rel="icon" href="/favicon.ico" />
		<script src="https://cdn.jsdelivr.net/npm/marked/lib/marked.umd.js"></script>
		<title>Thomas Spalter - Game Developer</title>
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<a class="brand-link" href="/">
					<span class="brand-mark">TS</span>
					<div>
						<p class="eyebrow">Game Developer</p>
						<strong>Thomas Spalter</strong>
					</div>
				</a>
				<nav class="site-nav" aria-label="Primary navigation">
					{navLinks.map((item) => (
						<a class={item.href === currentPath ? 'nav-link active' : 'nav-link'} href={item.href}>{item.label}</a>
					))}
				</nav>
			</header>

			<main class="site-main">
				<slot />
			</main>

			<footer class="site-footer">
				<p>Wanna build something great together? <a href="/contact">Let's get in touch.</a></p>
			</footer>
		</div>
	</body>
</html>

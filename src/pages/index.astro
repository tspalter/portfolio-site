---
import Layout from '../layouts/Layout.astro';
const featuredProjects = [
	{
		title: 'Pulse Engine',
		description: 'A combat system prototype built for responsive action, tuned with polish and performance in mind.',
		meta: 'Systems · Combat · Unity',
		image: '/images/pulse-engine.svg',
		href: '/projects',
	},
	{
		title: 'Skyline Drift',
		description: 'A spatial platformer with architecture-driven level design and immersive player flow.',
		meta: 'Design · Player movement · Unreal',
		image: '/images/skyline-drift.svg',
		href: '/projects',
	},
	{
		title: 'Spatial Dialogue',
		description: "Master's thesis project exploring narrative systems inside procedural environments.",
		meta: 'Research · Narrative · Interactive spaces',
		image: '/images/spatial-dialogue.svg',
		href: '/projects',
	},
];
---

<Layout currentPath="/">
	<section class="section">
		<div class="section-header">
			<span class="section-label">Home</span>
			<h1 class="page-title">Game development work built to stand out.</h1>
			<p class="lead">I create gameplay systems, interactive worlds, and creative tools for games that need strong mechanics, polish, and player-first clarity.</p>
		</div>

		<div class="reel-container">
			<button class="reel-arrow left" id="reelLeft">&larr;</button>
			<div class="reel" id="reel">
				<div class="reel-item">
					<img src="/images/architecture-portfolio.svg" alt="Photo 1" />
				</div>
				<div class="reel-item">
					<video src="/videos/placeholder1.mp4" muted loop autoplay></video>
				</div>
				<div class="reel-item">
					<img src="/images/skyline-drift.svg" alt="Photo 2" />
				</div>
				<div class="reel-item">
					<video src="/videos/placeholder2.mp4" muted loop autoplay></video>
				</div>
				<div class="reel-item">
					<img src="/images/spatial-dialogue.svg" alt="Photo 3" />
				</div>
				<div class="reel-item">
					<video src="/videos/placeholder3.mp4" muted loop autoplay></video>
				</div>
			</div>
			<button class="reel-arrow right" id="reelRight">&rarr;</button>
		</div>

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const reel = document.getElementById('reel') as HTMLElement | null;
				const leftArrow = document.getElementById('reelLeft') as HTMLButtonElement | null;
				const rightArrow = document.getElementById('reelRight') as HTMLButtonElement | null;
				if (!reel || !leftArrow || !rightArrow) return;
				const reelElement = reel;

				const originalItems = Array.from(reelElement.children) as HTMLElement[];
				const totalItems = originalItems.length;
				let currentIndex = 0;
				let isTransitioning = false;

				const firstClone = originalItems[0].cloneNode(true) as HTMLElement;
				const lastClone = originalItems[totalItems - 1].cloneNode(true) as HTMLElement;
				reel.insertBefore(lastClone, reel.firstChild);
				reel.appendChild(firstClone);

				function updatePosition(index: number, instant = false) {
					reelElement.style.transition = instant ? 'none' : 'transform 0.5s ease';
					reelElement.style.transform = `translateX(-${(index + 1) * 100}%)`;

					if (instant) {
						requestAnimationFrame(() => {
							requestAnimationFrame(() => {
								reelElement.style.transition = 'transform 0.5s ease';
							});
						});
					}
				}

				function nextItem() {
					if (isTransitioning) return;
					isTransitioning = true;
					currentIndex += 1;
					updatePosition(currentIndex);
				}

				function prevItem() {
					if (isTransitioning) return;
					isTransitioning = true;
					currentIndex -= 1;
					updatePosition(currentIndex);
				}

				reel.addEventListener('transitionend', () => {
					if (currentIndex >= totalItems) {
						currentIndex = 0;
						updatePosition(currentIndex, true);
					} else if (currentIndex < 0) {
						currentIndex = totalItems - 1;
						updatePosition(currentIndex, true);
					}
					isTransitioning = false;
				});

				leftArrow.addEventListener('click', prevItem);
				rightArrow.addEventListener('click', nextItem);

				// Auto scroll every 15 seconds
				setInterval(nextItem, 15000);
			});
		</script>
	</section>

	<section class="section">
		<div class="section-header">
			<span class="section-label">Featured projects</span>
			<h2>Highlights from my portfolio</h2>
		</div>

		<div class="cards">
			{featuredProjects.map((project) => (
				<article class="card">
					<img src={project.image} alt={project.title} class="card-image" />
					<div class="card-content">
						<h2 class="card-title">{project.title}</h2>
						<p class="card-meta">{project.meta}</p>
						<p class="card-text">{project.description}</p>
						<div class="card-footer">
							<a class="button" href={project.href}>Explore project</a>
						</div>
					</div>
				</article>
			))}
		</div>
	</section>
</Layout>

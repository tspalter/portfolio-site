---
import Layout from '../layouts/Layout.astro';
const featuredProjects = [
	{
		title: 'Ball 2 the Wall',
		description: 'A puzzle platformer prototype developed in a custom engine as part of a team.',
		meta: 'Level Design · Tools · Custom Engine',
		image: '/images/B2TW.png',
		href: '/projects',
	},
	{
		title: 'ConCaveity',
		description: 'A stealth platformer with simple yet elegant level design and immersive player flow.',
		meta: 'Design · Mechanics · Custom Engine',
		image: '/images/ConCaveity.png',
		href: '/projects',
	},
	{
		title: 'Geospatial City Generator',
		description: "Master's thesis project exploring procedural city generation based on real-world data.",
		meta: 'Research · Geospatial Data · Unity',
		image: '/images/Thesis.png',
		href: '/projects',
	},
];
---

<Layout currentPath="/">
	<section class="section">
		<div class="section-header">
			<span class="section-label">Home</span>
			<h1 class="page-title">Developer, Engineer, Designer, Creator</h1>
			<p class="lead">Hi!  My name is Thomas, and I make games.  Thank you for visiting my website and I hope you enjoy your stay!</p>
		</div>

		<div class="reel-container">
			<button class="reel-arrow left" id="reelLeft">&larr;</button>
			<div class="reel" id="reel">
				<div class="reel-item">
					<img src="/images/Thesis Project.png" alt="Thesis Project" />
				</div>
				<div class="reel-item">
					<video src="/videos/Concaveity_Reel.mp4" muted loop autoplay></video>
				</div>
				<div class="reel-item">
					<img src="/images/Eye - Phase 3.gif" alt="Eye Boss" />
				</div>
				<div class="reel-item">
					<video src="/videos/B2TW_Reel.mp4" muted loop autoplay></video>
				</div>
				<div class="reel-item">
					<img src="/images/Linked Legend.png" alt="Linked Legend" />
				</div>
				<div class="reel-item">
					<video src="/videos/Concaveity_Reel_2.mp4" muted loop autoplay></video>
				</div>
			</div>
			<button class="reel-arrow right" id="reelRight">&rarr;</button>
		</div>

		<script is:inline>
			(function initReel() {
				const reel = document.getElementById('reel');
				const leftArrow = document.getElementById('reelLeft');
				const rightArrow = document.getElementById('reelRight');
				
				// Debug logging to pinpoint exactly what is missing if it still fails
				if (!reel || !leftArrow || !rightArrow) {
					console.error("Reel initialization failed. Missing elements:", { reel, leftArrow, rightArrow });
					return;
				}

				const originalItems = Array.from(reel.children);
				const totalItems = originalItems.length;
				let currentIndex = 0;
				let isTransitioning = false;

				// Clone elements for seamless infinite loop
				const firstClone = originalItems[0].cloneNode(true);
				const lastClone = originalItems[totalItems - 1].cloneNode(true);
				reel.insertBefore(lastClone, reel.firstChild);
				reel.appendChild(firstClone);

				// Snap immediately to index 0 (the Thesis Project)
				updatePosition(currentIndex, true);

				function updatePosition(index, instant = false) {
					reel.style.transition = instant ? 'none' : 'transform 0.7s ease';
					reel.style.transform = `translateX(-${(index + 1) * 100}%)`;

					if (instant) {
						requestAnimationFrame(() => {
							requestAnimationFrame(() => {
								reel.style.transition = 'transform 0.7s ease';
							});
						});
					}
				}

				function nextItem() {
					if (isTransitioning) return;
					isTransitioning = true;
					currentIndex += 1;
					updatePosition(currentIndex);
				}

				function prevItem() {
					if (isTransitioning) return;
					isTransitioning = true;
					currentIndex -= 1;
					updatePosition(currentIndex);
				}

				reel.addEventListener('transitionend', () => {
					if (currentIndex >= totalItems) {
						currentIndex = 0;
						updatePosition(currentIndex, true);
					} else if (currentIndex < 0) {
						currentIndex = totalItems - 1;
						updatePosition(currentIndex, true);
					}
					isTransitioning = false;
				});

				leftArrow.addEventListener('click', prevItem);
				rightArrow.addEventListener('click', nextItem);
			})();
		</script>
	</section>

	<section class="section">
		<div class="section-header">
			<span class="section-label">Featured projects</span>
			<h2>Highlights from my portfolio</h2>
		</div>

		<div class="cards">
			{featuredProjects.map((project) => (
				<article class="card">
					<img src={project.image} alt={project.title} class="card-image" />
					<div class="card-content">
						<h2 class="card-title">{project.title}</h2>
						<p class="card-meta">{project.meta}</p>
						<p class="card-text">{project.description}</p>
						<div class="card-footer">
							<a class="button" href={project.href}>Explore project</a>
						</div>
					</div>
				</article>
			))}
		</div>
	</section>
</Layout>

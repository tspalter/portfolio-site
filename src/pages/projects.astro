---
import Layout from '../layouts/Layout.astro';
const projects = [
	{
		title: 'Ball 2 the Wall',
		summary: 'A puzzle platformer in a neon setting where you roll, bounce, and press buttons with your balls to reach the goal.',
		role: 'Producer + Designer + Programmer',
		tech: 'Custom Engine, level design, C++, OpenGL',
		link: 'https://www.dropbox.com/scl/fi/22k279evuez4838n9dffd/Ball2TheWall_Setup.zip?rlkey=a29brbra5luyrif4qcxpqz4rg&st=1r1k77fx&dl=0',
		action: 'Download',
		image: '/images/B2TW.png',
	},
	{
		title: 'ConCaveity',
		summary: 'A stealth platformer where you navigate the dungeons, collect keys, and avoid the gaze of the Evil Eye.',
		role: 'Producer + Designer + Programmer',
		tech: 'Custom Engine, level design, C++, OpenGL',
		link: '/ConCaveity_Setup.zip',
		action: 'Download',
		image: '/images/ConCaveity.png',
	},
	{
		title: 'Master’s Thesis',
		summary: 'Master’s thesis project exploring real-world geospatial data and procedural generation techniques.',
		role: 'Lead Researcher',
		tech: 'Unity, ArcGIS, GeoJSON, TypeScript',
		link: 'https://example.com/thesis',
		action: 'Read case study',
		image: '/images/Thesis Project.png',
	},
	{
		title: 'Breakout Effect',
		summary: 'My first game project building a custom 2D game engine, developed with the help of learnopengl.com.',
		role: 'Lead Engineer + Designer',
		tech: 'Custom Engine, C++, OpenGL',
		link: '',
		action: 'Unavailable',
		image: '/images/Breakout Effect.png',
	},
	{
		title: 'Linked Legend',
		summary: 'A turn-based strategy game where you change the battle, change the course of history, and repeat.',
		role: 'Designer + Programmer',
		tech: 'Unity Engine, C#, Rhino for level design',
		link: '',
		action: 'Unavailable',
		image: '/images/Linked Legend.png',
	},
	{
		title: 'Architecture Portfolio',
		summary: 'Enjoy some of my early architecture design work and other creative projects from my undergraduate studies.',
		role: 'Designer',
		tech: 'Adobe Creative Suite, Rhino, AutoCAD, Revit',
		link: '/Portfolio_ThomasSpalter.zip',
		action: 'Download',
		image: '/images/Architecture_Portfolio.png',
	},
];
---

<Layout currentPath="/projects">
	<section class="section">
		<div class="section-header">
			<span class="section-label">Projects</span>
			<h1 class="page-title">Interactive Simulations, Thesis Research, and Polished Game Systems.</h1>
			<p class="lead">Here are some of the projects I've worked on, showcasing my skills in game development, research, and interactive design.  Please feel free to explore the links and downloads!</p>
		</div>

		<div class="cards">
			{projects.map((project) => (
				<article class="card">
					<img src={project.image} alt={project.title} class="card-image" />
					<div class="card-content">
						<h2 class="card-title">{project.title}</h2>
						<p class="card-meta">{project.role}</p>
						<p class="card-text">{project.summary}</p>
						<p class="card-meta">{project.tech}</p>
						<div class="project-actions">
							{project.link ? (
								<a class="button" href={project.link} target="_blank" rel="noreferrer">
									{project.action}
								</a>
							) : (
								<span class="button style-as-disabled">
									{project.action}
								</span>
							)}
						</div>
					</div>
				</article>
			))}
		</div>
	</section>
</Layout>

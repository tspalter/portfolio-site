---
import Layout from '../layouts/Layout.astro';
const education = [
	{ title: 'Master of Science in Computer Science', institution: 'DigiPen Institute of Technology', date: '2020-2023', details: 'Concentrations in game development, graphics, and AI.  I also wrote my master thesis on procedural content generation and its applications to the real world.' },
	{ title: 'Bachelor of Science in Architecture', institution: 'Washington University in St. Louis', date: '2015-2020', details: 'Second Major in Computer Science.  Developed a strong foundation in both design and programming principles.' },
];

const experience = [
	{ title: 'Junior Full Stack AR/VR Developer', company: 'Booz Allen Hamilton', date: '2023-2025', summary: 'Designed XR experiences and applications for military training purposes.  Primarily worked in Unity and C#.' },
	{ title: 'Technical Designer', company: 'Mojang Studios', date: '2022', summary: 'Helped work on the 2022 Mob Vote Live server, debugging minigames, collaborating with design and engineering teams, and taking charge on localization scripts for a global-scale event.  Programming was primarily done in TypeScript.' },
	{ title: 'Gameplay Programming Intern', company: 'BoardScore Inc.', date: '2022', summary: 'Worked on implementing and testing gameplay mechanics for YouRiding, a surfing game that simulates real-world locations and conditions.  Primarily worked in Unity and C# debugging issues, particularly with the camera system.' },
];

const projects = [
	{ title: 'IVER Maintenance Course Creator', role: 'Lead Programmer & Designer – Developed Unity-based training module for military maintenance procedures' },
	{ title: 'Project GoldenEye', role: 'Systems Engineer – Android Builds, HTC Vive Tracker synchronization for immmersive AR wargaming application' },
	{ title: 'MARFORPAC', role: 'Tools Programmer & Bug Scrum Leader – Developed custom build tool for creating multiple builds and handled bug reports' },
	{ title: 'OceanLens', role: 'Tools & Graphics Engineer – Debugged rendering issues and optimized performance to restore older project to modern Unity builds' },
	{ title: '2022 Mob Vote Live Server', role: 'Localization Engineer & Technical Designer – Debugged minigames and localized content for a global-scale event' },
	{ title: 'Real-World Geospatial City Generator', role: 'Lead Programmer & Designer – Extended a procedural city generation system to read real-world data and display in a Unity3D environment' },
	{ title: 'Ball 2 the Wall (B2TW)', role: 'Producer, Level Designer, Engine Programmer - Developed custom 3D game engine, led team meetings and coordinated development efforts, designed levels and art' },
	{ title: 'ConCaveity', role: 'Producer, Level Designer, Engine Programmer – Developed custom 2D game engine, led team meetings and coordinated development efforts, designed levels and art' },
	{ title: 'Linked Legend', role: 'Level Designer, Programmer – Designed levels and implemented gameplay mechanics related to different weapons and game balance' },
];

const certifications = [
	'Unity Certified Programmer:  User Level',
	'Responsive Web Design Certification, freeCodeCamp',
	'Inactive Secret Clearance, expires 03/2027',
];
---

<Layout currentPath="/cv">
	<section class="section">
		<div class="section-header">
			<span class="section-label">CV</span>
			<h1 class="page-title">Experience, Projects, and Certifications</h1>
			<p class="lead">This page details my core career and project experience that demonstrate what I've accomplished.</p>
		</div>

		<div class="grid-split">
			<div class="detail-block">
				<h2>Education</h2>
				<ul class="detail-list">
					{education.map((item) => (
						<li class="detail-item">
							<strong>{item.title}</strong>
							<span>{item.institution} • {item.date}</span>
							<p class="card-text">{item.details}</p>
						</li>
					))}
				</ul>
			</div>

			<div class="detail-block">
				<h2>Professional Experience</h2>
				<ul class="detail-list">
					{experience.map((item) => (
						<li class="detail-item">
							<strong>{item.title}</strong>
							<span>{item.company} • {item.date}</span>
							<p class="card-text">{item.summary}</p>
						</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section-header">
			<span class="section-label">Highlights</span>
			<h2>Projects and Certifications</h2>
		</div>

		<div class="grid-split">
			<div class="card">
				<h3 class="card-title">Projects</h3>
				<ul class="project-list">
					{projects.map((project) => (
						<li class="project-item">
							<strong>{project.title}</strong>
							<span>{project.role}</span>
						</li>
					))}
				</ul>
			</div>

			<div class="card">
				<h3 class="card-title">Certifications</h3>
				<ul class="cert-list">
					{certifications.map((cert) => (
						<li class="cert-item">{cert}</li>
					))}
				</ul>
			</div>
		</div>

		<div class="card card-footer resume-card">
			<p class="lead">Need a copy of my resume?  Click here to download!</p>
			<div class="resume-button-wrapper">
				<a class="button button-compact" href="/Resume_SpalterThomas_C.pdf" download>Download Resume</a>
			</div>
		</div>

		<div class="card card-footer resume-card">
			<p class="lead">Here are some links to my additional work and social media:</p>
			<div class="resume-button-wrapper">
				<a class="button button-compact" href="https://github.com/tspalter" target="_blank" rel="noopener noreferrer">GitHub</a>
				<a class="button button-compact" href="https://www.linkedin.com/in/thomas-spalter-1aa303152/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
			</div>
		</div>
	</section>
</Layout>

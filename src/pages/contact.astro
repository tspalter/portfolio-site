---
import Layout from '../layouts/Layout.astro';
---

<Layout currentPath="/contact">
	<section class="section">
		<div class="section-header">
			<span class="section-label">Contact Me</span>
			<h1 class="page-title">Let’s connect and build something exceptional.</h1>
			<p class="lead">I’m available for full-time and contract roles in game development, systems design, and interactive production.</p>
		</div>

		<div class="contact-grid">
			<div class="contact-card">
				<h2>Contact details</h2>
				<p class="card-text">Feel free to reach out directly with opportunities or questions about my work.</p>
				<p><strong>Email:</strong> <a href="mailto:thomasspalter@gmail.com">thomasspalter@gmail.com</a></p>
				<p><strong>Phone:</strong> <a href="tel:+1234567890">+1 (479) 866-0109</a></p>
				<p><strong>Location:</strong> Based in the greater Seattle area, open to remote opportunities.</p>
			</div>

			<div class="cta-banner">
				<h2>Prefer a quick intro?</h2>
				<p class="card-text">Send a short message with your project, the role you’re hiring for, and the team goals. I’ll respond promptly with examples that match your needs.</p>
				<a class="button" href="mailto:thomasspalter@gmail.com">Email me</a>
			</div>
		</div>
	</section>
</Layout>
